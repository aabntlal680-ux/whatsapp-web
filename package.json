{
  "name": "workspace",
  "main": "index.js",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" && exit 0 ;; esac'",
    "build": "pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.2.2"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "expo": "~51.0.34",
    "express": "^5.2.1",
    "react-native-webview": "^13.16.1"
  }
}
